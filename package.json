    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.2",
