    "@orpc/client": "^1.14.3",
    "@orpc/json-schema": "^1.14.3",
    "@orpc/openapi": "^1.14.3",
    "@orpc/server": "^1.14.3",
    "@orpc/tanstack-query": "^1.14.3",
    "@orpc/zod": "^1.14.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/query-core": "latest",
    "@tanstack/react-devtools": "latest",
